# DevTools Terminator - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# CRITICAL SECURITY REQUIREMENT:
# Generate a strong random secret for production:
#   openssl rand -hex 32
# OR
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Server secret for HMAC-SHA256 signature validation
# This MUST match the client-side secret configuration
# DO NOT use the default value in production!
DEVTOOLS_SECRET=your_secret_key_here

# Session secret for Express session middleware
# Generate a different secret from DEVTOOLS_SECRET
SESSION_SECRET=your_session_secret_here

# Node environment
NODE_ENV=development

# Server port (optional)
PORT=3000
